<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>UPB-CIENTÍFICA — Backups Cifrados</title>
    <style>
        body { font-family: Arial; margin: 0; background: #f0f2f5; }
        nav { background: #1a237e; color: white; padding: 1rem 2rem;
              display: flex; gap: 2rem; align-items: center; }
        nav a { color: white; text-decoration: none; }
        nav a:hover { text-decoration: underline; }
        .content { padding: 2rem; max-width: 800px; margin: 0 auto; }

        .status-card {
            background: white; border-radius: 8px; padding: 1.5rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 1.5rem;
            display: flex; align-items: center; gap: 1.5rem;
        }
        .status-icon { font-size: 3rem; }
        .status-info h3 { margin: 0 0 4px 0; }
        .status-info p { margin: 0; color: #666; font-size: 14px; }
        .badge {
            display: inline-block; padding: 3px 10px; border-radius: 12px;
            font-size: 12px; font-weight: bold;
        }
        .badge-ok { background: #e8f5e9; color: #2e7d32; }
        .badge-warn { background: #fff3e0; color: #e65100; }

        .btn {
            padding: 10px 20px; border: none; border-radius: 6px;
            cursor: pointer; font-size: 14px; font-weight: bold;
        }
        .btn-primary { background: #1a237e; color: white; }
        .btn-primary:hover { background: #283593; }
        .btn-primary:disabled { background: #9e9e9e; cursor: not-allowed; }

        .backup-list { background: white; border-radius: 8px;
                       box-shadow: 0 2px 5px rgba(0,0,0,0.1); overflow: hidden; }
        .backup-list h3 { margin: 0; padding: 1rem 1.5rem;
                          border-bottom: 1px solid #eee; font-size: 15px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 10px 16px; text-align: left; border-bottom: 1px solid #f0f0f0; }
        th { background: #fafafa; font-size: 13px; color: #666; }
        td { font-size: 14px; }
        tr:last-child td { border-bottom: none; }

        .gpg-key-box {
            background: #1a1a2e; color: #a8ff78; font-family: monospace;
            font-size: 11px; padding: 1rem; border-radius: 6px;
            word-break: break-all; margin-top: 1rem; display: none;
        }
        .empty { padding: 2rem; text-align: center; color: #999; }

        .alert {
            padding: 12px 16px; border-radius: 6px; margin-bottom: 1rem;
            display: none; font-size: 14px;
        }
        .alert-success { background: #e8f5e9; color: #2e7d32; border-left: 4px solid #4caf50; }
        .alert-error   { background: #ffebee; color: #c62828; border-left: 4px solid #f44336; }

        .info-box {
            background: #e3f2fd; border-left: 4px solid #2196f3;
            padding: 12px 16px; border-radius: 4px; font-size: 13px;
            margin-bottom: 1.5rem; color: #1565c0;
        }
        .spinner { display: none; margin-left: 8px; }
        .spinning { animation: spin 1s linear infinite; display: inline-block; }
        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <nav>
        <strong>UPB-CIENTÍFICA</strong>
        <a href="/dashboard">Dashboard</a>
        <a href="/files">Archivos</a>
        <a href="/photos">Fotos</a>
        <a href="/streaming">Streaming</a>
        <a href="/jobs">Jobs MPI</a>
        <a href="/backups">🔐 Backups</a>
        <a href="#" onclick="logout()">Salir</a>
    </nav>

    <div class="content">
        <h2>🔐 Backups Cifrados (GPG)</h2>

        <div class="info-box">
            Los backups se cifran con tu clave pública GPG (RSA 3072 bits).
            Solo tú, con tu clave privada, puedes descifrarlos.
            Ni el administrador del servidor puede acceder al contenido.
        </div>

        <div id="alertBox" class="alert"></div>

        <!-- Estado GPG -->
        <div class="status-card" id="statusCard">
            <div class="status-icon" id="statusIcon">⏳</div>
            <div class="status-info" style="flex:1">
                <h3 id="statusTitle">Verificando...</h3>
                <p id="statusDesc"></p>
                <div style="margin-top: 8px">
                    <span class="badge" id="statusBadge">...</span>
                </div>
            </div>
            <div>
                <button class="btn btn-primary" id="btnBackup"
                        onclick="triggerBackup()" disabled>
                    🗄️ Crear backup ahora
                    <span class="spinner" id="spinner">⏳</span>
                </button>
            </div>
        </div>

        <!-- Clave pública (toggle) -->
        <div id="gpgKeySection" style="display:none; margin-bottom: 1.5rem;">
            <button class="btn" style="background:#e8eaf6;color:#1a237e;"
                    onclick="toggleKey()">
                🔑 Ver mi clave pública GPG
            </button>
            <div class="gpg-key-box" id="gpgKeyBox"></div>
        </div>

        <!-- Lista de backups -->
        <div class="backup-list">
            <h3>📦 Backups disponibles <span id="backupCount" style="color:#999;font-weight:normal;font-size:13px"></span></h3>
            <div id="backupTableContainer">
                <div class="empty">Cargando...</div>
            </div>
        </div>

        <!-- Instrucciones de descifrado -->
        <details style="margin-top:1.5rem;">
            <summary style="cursor:pointer; padding: 0.5rem; font-weight:bold; color:#1a237e;">
                ¿Cómo descifrar un backup?
            </summary>
            <div style="background:white; padding:1.5rem; border-radius:0 0 8px 8px;
                        box-shadow: 0 2px 5px rgba(0,0,0,0.1); font-size:14px;">
                <p><strong>1. Obtén tu clave privada GPG</strong> del administrador del sistema.</p>
                <p><strong>2. Importa tu clave privada:</strong></p>
                <pre style="background:#1a1a2e;color:#a8ff78;padding:1rem;border-radius:4px;overflow-x:auto">
gpg --import tu_clave_privada.gpg</pre>
                <p><strong>3. Descifra el backup:</strong></p>
                <pre style="background:#1a1a2e;color:#a8ff78;padding:1rem;border-radius:4px;overflow-x:auto">
gpg --decrypt backup_20260611_020000.tar.gz.gpg | tar -xzf -</pre>
                <p style="color:#666;">
                    Esto descomprime el contenido de tu Home completo en el directorio actual.
                </p>
            </div>
        </details>
    </div>

    <script>
        let gpgKeyContent = '';

        async function loadStatus() {
            try {
                const res = await fetch('/api/backups/status');
                const data = await res.json();

                const icon = document.getElementById('statusIcon');
                const title = document.getElementById('statusTitle');
                const desc = document.getElementById('statusDesc');
                const badge = document.getElementById('statusBadge');
                const btn = document.getElementById('btnBackup');
                const keySection = document.getElementById('gpgKeySection');

                if (data.hasGpgKey) {
                    icon.textContent = '🔐';
                    title.textContent = 'Cifrado GPG activo';
                    desc.textContent = 'Tu clave pública está registrada en el servidor.';
                    badge.textContent = '✓ Protegido con GPG RSA-3072';
                    badge.className = 'badge badge-ok';
                    btn.disabled = false;
                    keySection.style.display = 'block';
                    // Cargar clave para mostrar
                    loadPublicKey();
                } else {
                    icon.textContent = '⚠️';
                    title.textContent = 'Sin clave GPG configurada';
                    desc.textContent = 'Contacta al administrador para generar tu par de claves GPG.';
                    badge.textContent = '✗ Sin protección GPG';
                    badge.className = 'badge badge-warn';
                    btn.disabled = true;
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function loadPublicKey() {
            try {
                // Leer la clave pública vía el endpoint de perfil o directamente
                const res = await fetch('/api/backups/pubkey');
                if (res.ok) {
                    const data = await res.json();
                    gpgKeyContent = data.publicKey;
                }
            } catch {}
        }

        async function loadBackups() {
            try {
                const res = await fetch('/api/backups');
                const data = await res.json();

                document.getElementById('backupCount').textContent =
                    '(' + data.backups.length + ')';

                const container = document.getElementById('backupTableContainer');

                if (data.backups.length === 0) {
                    container.innerHTML = '<div class="empty">No hay backups aún. Crea uno con el botón de arriba.</div>';
                    return;
                }

                container.innerHTML = `
                    <table>
                        <thead>
                            <tr>
                                <th>Archivo</th>
                                <th>Tamaño</th>
                                <th>Creado</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${data.backups.map(b => `
                                <tr>
                                    <td>🔒 ${b.name}</td>
                                    <td>${formatBytes(b.size)}</td>
                                    <td>${new Date(b.created).toLocaleString()}</td>
                                    <td><span class="badge badge-ok">Cifrado GPG</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                `;
            } catch (err) {
                console.error(err);
            }
        }

        async function triggerBackup() {
            const btn = document.getElementById('btnBackup');
            const spinner = document.getElementById('spinner');
            btn.disabled = true;
            spinner.style.display = 'inline';
            spinner.classList.add('spinning');

            try {
                const res = await fetch('/api/backups/trigger', { method: 'POST' });
                const data = await res.json();

                showAlert(data.message || 'Backup iniciado', 'success');

                // Esperar 5 segundos y recargar la lista
                setTimeout(() => {
                    loadBackups();
                    btn.disabled = false;
                    spinner.style.display = 'none';
                    spinner.classList.remove('spinning');
                }, 5000);

            } catch (err) {
                showAlert('Error al iniciar el backup: ' + err.message, 'error');
                btn.disabled = false;
                spinner.style.display = 'none';
            }
        }

        function toggleKey() {
            const box = document.getElementById('gpgKeyBox');
            if (box.style.display === 'none' || box.style.display === '') {
                box.style.display = 'block';
                box.textContent = gpgKeyContent || '(Cargando clave...)';
            } else {
                box.style.display = 'none';
            }
        }

        function showAlert(msg, type) {
            const box = document.getElementById('alertBox');
            box.textContent = msg;
            box.className = 'alert alert-' + type;
            box.style.display = 'block';
            setTimeout(() => { box.style.display = 'none'; }, 5000);
        }

        function formatBytes(b) {
            if (!b) return '0 B';
            const k = 1024, s = ['B','KB','MB','GB'];
            const i = Math.floor(Math.log(b)/Math.log(k));
            return parseFloat((b/Math.pow(k,i)).toFixed(1)) + ' ' + s[i];
        }

        async function logout() {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        }

        // Cargar todo al inicio
        loadStatus();
        loadBackups();
    </script>
</body>
</html>