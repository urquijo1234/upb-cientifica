<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>UPB-CIENTÍFICA — Streaming</title>
    <style>
        body { font-family: Arial; margin: 0; background: #1a1a2e; color: #eee; }
        nav { background: #16213e; padding: 1rem 2rem;
              display: flex; gap: 2rem; align-items: center; }
        nav a { color: #a8b2d8; text-decoration: none; }
        nav a:hover, nav a.active { color: white; }
        .content { display: flex; height: calc(100vh - 60px); }
        .sidebar { width: 320px; background: #16213e; overflow-y: auto; padding: 1rem; flex-shrink: 0; }
        .sidebar h3 { margin-top: 0; color: #a8b2d8; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; }
        .video-list { list-style: none; padding: 0; margin: 0; }
        .video-item { padding: 10px 12px; border-radius: 6px; cursor: pointer; margin-bottom: 4px;
                      display: flex; align-items: center; gap: 10px; }
        .video-item:hover { background: #0f3460; }
        .video-item.active { background: #533483; }
        .video-item .title { font-size: 13px; white-space: nowrap; overflow: hidden;
                             text-overflow: ellipsis; flex: 1; }
        .video-item .meta { font-size: 11px; color: #8892b0; }
        .player-area { flex: 1; display: flex; flex-direction: column;
                       justify-content: center; align-items: center; padding: 2rem; }
        video { max-width: 100%; max-height: 70vh; border-radius: 8px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.5); background: #000; }
        .video-title { margin-top: 1rem; font-size: 18px; font-weight: 600; }
        .empty-player { text-align: center; color: #8892b0; }
        .empty-player .icon { font-size: 5rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <nav>
        <strong style="color:white">UPB-CIENTÍFICA</strong>
        <a href="/dashboard">Dashboard</a>
        <a href="/files">Archivos</a>
        <a href="/photos">Fotos</a>
        <a href="/streaming" class="active">Streaming</a>
        <a href="/backups">Backups</a>
        <a href="/jobs">Jobs MPI</a>
        <a href="#" onclick="logout()">Salir</a>
    </nav>
    <div class="content">
        <div class="sidebar">
            <h3>🎬 Videos (<span id="videoCount">0</span>)</h3>
            <ul class="video-list" id="videoList"></ul>
        </div>
        <div class="player-area">
            <div class="empty-player" id="emptyState">
                <div class="icon">▶️</div>
                <p>Selecciona un video de la lista para reproducirlo</p>
                <p style="font-size:12px;">Formatos soportados: MP4, WebM, MKV</p>
            </div>
            <video id="player" controls style="display:none" crossorigin="anonymous">
                Tu navegador no soporta el elemento video.
            </video>
            <div class="video-title" id="videoTitle" style="display:none"></div>
        </div>
    </div>

    <script>
        let videos = [];
        let currentIdx = -1;

        async function loadVideos() {
            const res = await fetch('/api/streaming');
            const data = await res.json();
            videos = data.videos;
            document.getElementById('videoCount').textContent = videos.length;

            const list = document.getElementById('videoList');
            if (videos.length === 0) {
                list.innerHTML = '<li style="color:#8892b0;font-size:13px;padding:10px">No hay videos. Sube .mp4 o .webm en la sección Archivos.</li>';
                return;
            }

            list.innerHTML = videos.map((v, i) => `
                <li class="video-item" onclick="play(${i})" id="item-${i}">
                    <span>🎬</span>
                    <div>
                        <div class="title">${v.name}</div>
                        <div class="meta">${formatBytes(v.size)}</div>
                    </div>
                </li>
            `).join('');
        }

        function play(idx) {
            const video = videos[idx];
            currentIdx = idx;

            // Actualizar estado activo en sidebar
            document.querySelectorAll('.video-item').forEach(el => el.classList.remove('active'));
            document.getElementById('item-' + idx).classList.add('active');

            // Mostrar player
            const player = document.getElementById('player');
            document.getElementById('emptyState').style.display = 'none';
            player.style.display = 'block';
            document.getElementById('videoTitle').style.display = 'block';
            document.getElementById('videoTitle').textContent = video.name;

            // Cambiar source y reproducir
            player.src = '/api/streaming/play?path=' + encodeURIComponent(video.path);
            player.load();
            player.play().catch(() => {});
        }

        function formatBytes(b) {
            if (!b) return '0 B';
            const k = 1024, s = ['B','KB','MB','GB'];
            const i = Math.floor(Math.log(b)/Math.log(k));
            return parseFloat((b/Math.pow(k,i)).toFixed(1)) + ' ' + s[i];
        }

        async function logout() {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        }

        loadVideos();
    </script>
</body>
</html>