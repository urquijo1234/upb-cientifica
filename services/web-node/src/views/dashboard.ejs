<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>UPB-CIENTÍFICA — Dashboard</title>
    <style>
        body { font-family: Arial; margin: 0; }
        nav { background: #1a237e; color: white; padding: 1rem 2rem;
              display: flex; gap: 2rem; align-items: center; }
        nav a { color: white; text-decoration: none; }
        nav a:hover { text-decoration: underline; }
        .content { padding: 2rem; }
        .card { background: white; border-radius: 8px; padding: 1.5rem;
                box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 1rem; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                gap: 1rem; }
    </style>
</head>
<body>
    <nav>
        <strong>UPB-CIENTÍFICA EQUIPO ALPHA</strong>
        <a href="/dashboard">Dashboard</a>
        <a href="/files">Archivos</a>
        <a href="/photos">Fotos</a>
        <a href="/streaming">Streaming</a>
        <a href="/backups">Backups</a>
        <a href="/jobs">Trabajos MPI</a>
        <a href="#" onclick="logout()">Salir</a>
    </nav>
    <div class="content">
        <h2>Dashboard</h2>
        <div class="grid">
            <div class="card">
                <h3>Shared File</h3>
                <p>Gestiona tus archivos</p>
                <a href="/files">Ir a Archivos →</a>
            </div>
            <div class="card">
                <h3>Photo Album</h3>
                <p>Explora tus imágenes</p>
                <a href="/photos">Ir a Fotos →</a>
            </div>
            <div class="card">
                <h3>Streaming</h3>
               
                <a href="/streaming">Ir a Streaming →</a>
            </div>
            <div class="card">
                <h3>Backups</h3>
                <p>Explora tus backups</p>
                <a href="/backups">Ir a Backups →</a>
            </div>
            <div class="card">
                <h3>Trabajos MPI</h3>
                <p>Envía código al clúster HPC</p>
                <a href="/jobs">Ir a Jobs →</a>
            </div>
            <div class="card">
                <h3>File Sync</h3>
                <p>Estado: Sincronizado ✓</p>
            </div>
        </div>
    </div>
    <script>
        async function logout() {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        }
    </script>
</body>
</html>